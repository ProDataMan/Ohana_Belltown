{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ohana Menu Item",
  "type": "object",
  "required": ["id", "name", "category", "price", "available"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "price": { "type": "number" },
    "image": { "type": "string" },
    "available": { "type": "boolean" },
    "featured": { "type": "boolean" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
